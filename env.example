# ====================================
# CONFIGURACIÓN DE LA APLICACIÓN
# ====================================
NODE_ENV=development
PORT=5001
API_PREFIX=api/v1

# ====================================
# BASE DE DATOS - PostgreSQL
# ====================================
# Opción 1: URL completa (recomendado)
DATABASE_URL=postgresql://user:password@localhost:5432/andamiaje_db

# Opción 2: Configuración individual (comentado)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=andamiaje
# DB_PASSWORD=andamiaje
# DB_DATABASE=andamiaje_db
# DB_SYNCHRONIZE=false
# DB_LOGGING=true

# ====================================
# JWT - AUTENTICACIÓN
# ====================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your-super-secret-refresh-jwt-key-change-this-in-production
JWT_REFRESH_EXPIRES_IN=7d

# ====================================
# BACKBLAZE B2 - ALMACENAMIENTO
# ====================================
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
B2_REGION=us-west-004
B2_BUCKET=your-bucket-name
B2_KEY_ID=your-key-id
B2_APP_KEY=your-app-key
B2_BUCKET_ID=your-bucket-id

# ====================================
# CORS - ORÍGENES PERMITIDOS
# ====================================
ALLOWEDORIGINSPROD=http://localhost:3000,http://localhost:5173

# ====================================
# ARCHIVOS - CONFIGURACIÓN
# ====================================
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png

# ====================================
# LOGGING - WINSTON
# ====================================
LOG_LEVEL=info
LOG_DIR=./logs

# ====================================
# EMAIL - NOTIFICACIONES
# ====================================
# Servicio de email (gmail, outlook, sendgrid, smtp)
MAIL_SERVICE=gmail

# Para Gmail/Outlook
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Para SMTP personalizado (si no usas gmail/outlook)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false

# Configuración general
MAIL_FROM_NAME=Andamiaje API
MAIL_FROM_ADDRESS=noreply@andamiaje.com

# URL del frontend para enlaces en emails
FRONTEND_URL=http://localhost:3000

# Habilitar/deshabilitar envío de emails (útil para desarrollo)
MAIL_ENABLED=true

# ====================================
# NOTAS IMPORTANTES
# ====================================
# 1. Para Gmail: Habilita "Acceso de aplicaciones menos seguras" o usa "App Passwords"
#    https://support.google.com/accounts/answer/185833
#
# 2. Para producción: Usa variables de entorno del servidor, NO este archivo
#
# 3. NUNCA subas el archivo .env real a Git
#
# 4. Cambia TODOS los secrets en producción
#
# 5. Para SMTP personalizado, comenta MAIL_SERVICE y configura MAIL_HOST/PORT

